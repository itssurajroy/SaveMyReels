# Bot Configuration
BOT_TOKEN=your_telegram_bot_token_from_botfather

# Admin user IDs (comma-separated Telegram user IDs)
ADMIN_IDS=123456789

# Forced join channels (comma-separated, include @ prefix or chatId#inviteUrl)
FORCE_CHANNELS=-1004394968493#https://t.me/voidbots_support

# Real-time Activity Log Channel ID
LOG_CHANNEL_ID=-1004208710614

# Rate Limiting
DAILY_FREE_LIMIT=5
REFERRAL_BONUS=3

# Premium Pricing (Telegram Stars)
PREMIUM_PRICE_STARS=50
PREMIUM_DURATION_DAYS=30

# Video Settings
MAX_FILE_SIZE_MB=50
DEFAULT_QUALITY=hd
